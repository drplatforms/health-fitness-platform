    "process_doctrine": {
        "complex_backend_quality_gate": [
            "Diagnose current behavior before patching.",
            "Identify the exact failing, missing, or underperforming user path.",
            "Add a failing regression test, diagnostic test, or coverage test where practical.",
            "Confirm the test fails or exposes the gap before implementation.",
            "Apply the smallest safe implementation change.",
            "Prove the new test passes.",
            "Re-run prior milestone regression tests.",
            "Re-run the original manual/browser smoke path.",
            "Update project memory.",
            "Only then request Architecture acceptance."
        ],
        "risk_model": {
            "low": "docs/typo/isolated helper: normal patch and focused validation",
            "medium": "deterministic service or bounded integration: light diagnostic, focused test, narrow patch, regression validation, smoke if user-visible",
            "high": "workout generation, catalog selection/scoring, state/persistence, nutrition targets, provider output, recommendations: diagnostic first, failing/coverage test, narrow patch, regression validation, original smoke, Linux/browser smoke, project memory, Architecture acceptance"
        },
        "stop_conditions": [
            "same bug survives two implementation patches",
            "tests pass but browser smoke fails",
            "Linux smoke fails after Windows green",
            "candidate pools or data shape are unclear",
            "implementation requires broader scope than approved",
            "expected file-change budget is exceeded",
            "persistence/state behavior becomes unstable",
            "patch fails to apply because of drift and next step is not obvious",
            "branch accumulates unrelated fixes",
            "implementation crosses into deferred v2 scope"
        ],
        "bug_to_regression_rule": "Every real smoke failure becomes automated regression test, diagnostic/coverage test, documented limitation, or backlog item.",
        "v1_v2_scope_rule": "Architecture defines v1 acceptance and deferred v2 scope before implementation when a feature could expand.",
        "provider_ai_rule": "Provider may propose. Backend validates. User sees only approved output."
    },
