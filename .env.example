# API keys
OPENAI_API_KEY=

# App settings
ENVIRONMENT=local
DATABASE_URL=sqlite:///./data/fitness_ai.db

# Optional
LOG_LEVEL=INFO

# Recommendation candidate provider
RECOMMENDATION_CANDIDATE_PROVIDER=deterministic
RECOMMENDATION_CANDIDATE_TIMEOUT_SECONDS=45
CREWAI_RECOMMENDATION_MODEL=ollama/qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434

# Full health report provider
HEALTH_REPORT_PROVIDER=deterministic
HEALTH_REPORT_TIMEOUT_SECONDS=120
