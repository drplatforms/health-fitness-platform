# API keys
OPENAI_API_KEY=
FDC_API_KEY=

# Required only for Open Food Facts barcode fallback requests.
# Use an app identifier and non-private project contact value.
OPEN_FOOD_FACTS_USER_AGENT=HealthFitnessPlatform/1.0 (your-email@example.com)

# App settings
ENVIRONMENT=local
DATABASE_URL=sqlite:///./data/fitness_ai.db

# Optional logging
LOG_LEVEL=INFO

# Optional CrewAI workout runtime wiring.
# Deterministic remains the default. Set providers to crewai only for manual/debug QA.
WORKOUT_CANDIDATE_PROVIDER=deterministic
WORKOUT_EXPLANATION_PROVIDER=deterministic
CREWAI_WORKOUT_MODEL=ollama/qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434
CREWAI_WORKOUT_DISABLE_THINKING=true
CREWAI_WORKOUT_JSON_RESPONSE_FORMAT=true
