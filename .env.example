# API keys
OPENAI_API_KEY=
FDC_API_KEY=

# Required only for Open Food Facts barcode fallback requests.
# Use an app identifier and non-private project contact value.
OPEN_FOOD_FACTS_USER_AGENT=HealthFitnessPlatform/1.0 (your-email@example.com)

# App settings
ENVIRONMENT=local
DATABASE_URL=sqlite:///./data/fitness_ai.db

# Optional non-commercial/prototype animated exercise media.
# Set to ascendapi_free_v1 to enable the reviewed free hosted V1 allowlist.
# Revisit provider rights before any monetized or SaaS launch. No API key is used.
EXERCISE_VISUAL_MEDIA_PROVIDER=

# Optional logging
LOG_LEVEL=INFO

# Optional CrewAI workout runtime wiring.
# Deterministic remains the default. Set providers to crewai only for manual/debug QA.
WORKOUT_CANDIDATE_PROVIDER=deterministic
WORKOUT_EXPLANATION_PROVIDER=deterministic
CREWAI_WORKOUT_MODEL=ollama/qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434
CREWAI_WORKOUT_DISABLE_THINKING=true
CREWAI_WORKOUT_JSON_RESPONSE_FORMAT=true

# Optional AI Meal Ideas provider models. Provider choice remains explicit in the UI.
MEAL_IDEAS_LOCAL_MODEL=qwen3:8b
MEAL_IDEAS_OPENAI_MODEL=gpt-5.4-mini
MEAL_IDEAS_LOCAL_TIMEOUT_SECONDS=999
MEAL_IDEAS_OPENAI_TIMEOUT_SECONDS=60

# Optional Grounded Coach defaults. Provider/model remain user-selectable in Coach.
COACH_PROVIDER=local
COACH_LOCAL_MODEL=qwen3:8b
COACH_OPENAI_MODEL=gpt-5.4-mini
COACH_LOCAL_TIMEOUT_SECONDS=300
COACH_OPENAI_TIMEOUT_SECONDS=60
